<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_gradient"
        android:clipChildren="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/fragment_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <FrameLayout
            android:id="@+id/quick_server_update"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="68dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_quick_update_appbar_button"
            android:clickable="true"
            android:elevation="18dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:translationZ="18dp">

            <ImageView
                android:id="@+id/quick_server_update_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/update_current_subscription"
                android:src="@drawable/ic_baseline_refresh_24"
                android:tint="@color/quick_update_text" />

            <ProgressBar
                android:id="@+id/quick_server_update_progress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/quick_update_text"
                android:visibility="gone" />
        </FrameLayout>

        <View
            android:id="@+id/connect_ambient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:translationY="0dp"
            android:background="@drawable/bg_connect_ambient"
            app:layout_anchor="@id/fab"
            app:layout_anchorGravity="center" />

        <View
            android:id="@+id/connect_glow"
            android:layout_width="390dp"
            android:layout_height="390dp"
            android:alpha="0"
            android:translationY="0dp"
            android:background="@drawable/bg_connect_glow"
            app:layout_anchor="@id/fab"
            app:layout_anchorGravity="center" />

        <View
            android:id="@+id/connect_ring"
            android:layout_width="540dp"
            android:layout_height="540dp"
            android:alpha="0"
            android:translationY="0dp"
            android:background="@drawable/bg_connect_ring"
            app:layout_anchor="@id/fab"
            app:layout_anchorGravity="center" />

        <View
            android:id="@+id/connect_ring_soft"
            android:layout_width="660dp"
            android:layout_height="660dp"
            android:alpha="0"
            android:translationY="0dp"
            android:background="@drawable/bg_connect_ring_soft"
            app:layout_anchor="@id/fab"
            app:layout_anchorGravity="center" />


        <!-- We double trackThickness as half of it will be invisible -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/fabProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:max="1"
            android:visibility="invisible"
            app:indicatorColor="@color/connect_progress"
            app:indicatorSize="270dp"
            app:layout_anchor="@+id/fab"
            app:layout_anchorGravity="center"
            app:layout_behavior="io.nekohasekai.sagernet.widget.FabProgressBehavior"
            app:trackCornerRadius="@dimen/mtrl_progress_track_thickness"
            app:trackThickness="10dp" />

        <io.nekohasekai.sagernet.widget.ServiceButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="10dp"
            android:translationY="0dp"
            android:nextFocusDown="@+id/stats"
            app:backgroundTint="@color/connect_fab_background"
            app:fabCustomSize="210dp"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center_horizontal|center_vertical"
            app:maxImageSize="111dp"
            app:pressedTranslationZ="8dp"
            app:rippleColor="@color/connect_fab_ripple"
            app:srcCompat="@drawable/ic_service_idle" />

        <io.nekohasekai.sagernet.widget.StatsBar
            android:id="@+id/stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:nextFocusUp="@+id/fab"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                style="@style/Widget.SagerNet.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_location_picker_delay"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_baseline_download_24"
                                android:tint="@android:color/white" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="@string/speed_download"
                                android:textAllCaps="false"
                                android:textColor="@color/quick_bar_text_inactive"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/rx"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:textColor="@color/glass_text"
                                android:textLocale="en-US"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="24 KB/s" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:background="@color/glass_stroke" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_location_picker_delay"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_file_file_upload"
                                android:tint="@android:color/white" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:text="@string/speed_upload"
                                android:textAllCaps="false"
                                android:textColor="@color/quick_bar_text_inactive"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tx"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:ellipsize="end"
                                android:singleLine="true"
                                android:textColor="@color/glass_text"
                                android:textLocale="en-US"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="8 KB/s" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/location_card"
                style="@style/Widget.SagerNet.Card"
                android:layout_width="wrap_content"
                android:layout_height="72dp"
                android:layout_marginStart="8dp"
                android:alpha="0"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_location_badge"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/location_flag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌍"
                        android:textSize="28sp" />

                    <ImageView
                        android:id="@+id/location_switch"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@string/quick_connection_method"
                        android:src="@drawable/ic_baseline_compare_arrows_24"
                        android:tint="@color/glass_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </io.nekohasekai.sagernet.widget.StatsBar>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/startup_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_main_gradient"
            android:clickable="true"
            android:focusable="true"
            android:elevation="30dp"
            android:translationZ="30dp"
            android:visibility="gone"
            android:padding="32dp"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center">

            <TextView
                android:id="@+id/startup_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/startup_brand_name"
                android:textColor="@color/glass_text"
                android:textSize="34sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/startup_brand_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.25"
                app:layout_constraintVertical_chainStyle="packed" />

            <ImageView
                android:id="@+id/startup_brand_icon"
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:layout_marginTop="14dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/app_name"
                android:src="@mipmap/ic_launcher_foreground"
                app:layout_constraintBottom_toTopOf="@id/startup_loading_progress"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/startup_brand" />

            <TextView
                android:id="@+id/startup_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/startup_checking_servers"
                android:textColor="@color/glass_text"
                android:textSize="14sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/startup_loading_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:indeterminate="true"
                android:progressTint="@color/quick_bar_button_text"
                android:progressBackgroundTint="@color/glass_stroke"
                android:layout_marginBottom="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:itemIconTint="@color/navigation_icon"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_black"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:itemIconTint="@color/navigation_icon"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemShapeFillColor="@color/navigation_item"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
