<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_gradient"
        android:clipChildren="false">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/fragment_holder"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:id="@+id/connect_ambient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:translationY="48dp"
            android:background="@drawable/bg_connect_ambient"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center_horizontal|center_vertical" />

        <View
            android:id="@+id/connect_glow"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:alpha="0"
            android:translationY="48dp"
            android:background="@drawable/bg_connect_glow"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center_horizontal|center_vertical" />

        <View
            android:id="@+id/connect_ring"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:alpha="0"
            android:translationY="48dp"
            android:background="@drawable/bg_connect_ring"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center_horizontal|center_vertical" />

        <View
            android:id="@+id/connect_ring_soft"
            android:layout_width="360dp"
            android:layout_height="360dp"
            android:alpha="0"
            android:translationY="48dp"
            android:background="@drawable/bg_connect_ring_soft"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center_horizontal|center_vertical" />


        <!-- We double trackThickness as half of it will be invisible -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/fabProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:max="1"
            android:visibility="invisible"
            app:indicatorColor="@color/connect_progress"
            app:indicatorSize="180dp"
            app:layout_anchor="@+id/fab"
            app:layout_anchorGravity="center"
            app:layout_behavior="io.nekohasekai.sagernet.widget.FabProgressBehavior"
            app:trackCornerRadius="@dimen/mtrl_progress_track_thickness"
            app:trackThickness="10dp" />

        <io.nekohasekai.sagernet.widget.ServiceButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="10dp"
            android:translationY="48dp"
            android:nextFocusDown="@+id/stats"
            app:backgroundTint="@color/connect_fab_background"
            app:fabCustomSize="136dp"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center_horizontal|center_vertical"
            app:maxImageSize="64dp"
            app:pressedTranslationZ="8dp"
            app:rippleColor="@color/connect_fab_ripple"
            app:srcCompat="@drawable/ic_service_idle" />

        <io.nekohasekai.sagernet.widget.StatsBar
            android:id="@+id/stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="12dp"
            android:nextFocusUp="@+id/fab"
            android:gravity="center"
            android:orientation="horizontal"
            android:translationY="156dp"
            app:layout_anchor="@id/fab"
            app:layout_anchorGravity="center_horizontal|bottom">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="260dp"
                android:layout_height="62dp"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/glass_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="6dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_baseline_download_24"
                                android:tint="@color/brand_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/speed_download"
                                android:textAllCaps="false"
                                android:textColor="@color/glass_text"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/rx"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:singleLine="true"
                            android:textColor="@color/glass_text"
                            android:textLocale="en-US"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="24 KB/s" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@color/glass_stroke" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginEnd="6dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_file_file_upload"
                                android:tint="@color/connect_fab_background_connected" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/speed_upload"
                                android:textAllCaps="false"
                                android:textColor="@color/glass_text"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tx"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:singleLine="true"
                            android:textColor="@color/glass_text"
                            android:textLocale="en-US"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="8 KB/s" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </io.nekohasekai.sagernet.widget.StatsBar>

        <LinearLayout
            android:id="@+id/startup_loading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_main_gradient"
            android:visibility="gone"
            android:padding="32dp"
            app:layout_anchor="@id/fragment_holder"
            app:layout_anchorGravity="center">

            <ProgressBar
                android:id="@+id/startup_loading_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/startup_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/glass_text"
                android:textSize="14sp"
                android:text="@string/startup_dedicated_checking" />
        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:itemIconTint="@color/navigation_icon"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_black"
        style="@style/Widget.Design.NavigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:itemIconTint="@color/navigation_icon"
        app:itemShapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent"
        app:itemShapeFillColor="@color/navigation_item"
        app:itemTextColor="@color/navigation_icon"
        app:menu="@menu/main_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
