<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.ConfigurationFragment">

    <include
        layout="@layout/layout_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/quick_bar_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:animateLayoutChanges="true"
        android:background="@drawable/bg_quick_bar"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="22dp"
        app:cardElevation="12dp"
        app:strokeColor="@color/quick_bar_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/quick_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="8dp"
                android:text="@string/quick_connection_method"
                android:textColor="@color/quick_bar_text_inactive"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/quick_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="ltr"
                android:padding="6dp"
                app:checkedButton="@id/quick_auto"
                app:selectionRequired="true"
                app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quick_youtube"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:text="@string/quick_youtube_instagram"
                android:textSize="12sp"
                app:backgroundTint="@color/quick_bar_button_bg"
                app:cornerRadius="14dp"
                app:strokeColor="@android:color/transparent"
                android:textColor="@color/quick_bar_button_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quick_auto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:text="@string/menu_auto_select"
                android:textSize="12sp"
                app:backgroundTint="@color/quick_bar_button_bg"
                app:cornerRadius="14dp"
                app:strokeColor="@android:color/transparent"
                android:textColor="@color/quick_bar_button_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quick_dedicated"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:text="@string/quick_dedicated_config"
                android:textSize="12sp"
                app:backgroundTint="@color/quick_bar_button_bg"
                app:cornerRadius="14dp"
                app:strokeColor="@android:color/transparent"
                android:textColor="@color/quick_bar_button_text" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quick_update_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_quick_update_button"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:text="بروزرسانی"
                android:textAllCaps="false"
                android:textColor="@color/quick_update_text"
                android:textSize="12sp"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_baseline_update_24"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="@color/quick_update_text" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/group_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?colorPrimary"
        android:elevation="4dp"
        android:visibility="gone"
        app:tabIndicatorColor="?tabIndicatorColor"
        app:tabIndicatorFullWidth="false"
        app:tabMode="scrollable"
        app:tabPaddingStart="16dp"
        app:tabRippleColor="?tabRippleColor"
        app:tabSelectedTextColor="?tabSelectedTextColor"
        app:tabTextColor="?tabTextColor"
        app:tabUnboundedRipple="false" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/group_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
