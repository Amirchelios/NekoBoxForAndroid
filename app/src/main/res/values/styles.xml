<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.SagerNet.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_surface</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">6dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.SagerNet.Card.Compact" parent="Widget.SagerNet.Card">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <style name="Widget.SagerNet.SectionTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.SagerNet.BodyMuted" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:fontFamily">@font/jetbrains_mono</item>
        <item name="fontFamily">@font/jetbrains_mono</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:alpha">0.78</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

</resources>
